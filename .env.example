# Variables d'environnement de l'editeur hebergé.
# En LOCAL  : copie ce fichier en `.env` (gitignore) et remplis les valeurs.
# En PROD   : configure ces variables dans Netlify (Site settings > Environment variables).
# Ne JAMAIS committer les vraies valeurs.

# --- GitHub : ecriture des .txt via commit ---
# Token (fine-grained OU classic scope `repo`) avec droit d'ecriture sur RuffDood/Diablo.
# Sans lui, l'editeur reste en LECTURE SEULE (la lecture d'un repo public ne demande pas de token).
GITHUB_TOKEN=

# --- Auth : cookie de session ---
# Chaine aleatoire pour signer les cookies (obligatoire pour activer l'auth).
# Genere-en une, ex : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Courriels autorises a se connecter (separes par des virgules).
ALLOWED_EMAILS=gbarriere@spheredi.com

# --- Optionnel : cibler un autre depot / branche ---
# GITHUB_OWNER=RuffDood
# GITHUB_REPO=Diablo
# GITHUB_BRANCH=main
