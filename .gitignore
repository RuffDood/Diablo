# Dependances
node_modules/

# Sorties de build
dist/
.turbo/
*.obj
*.lib
*.exp
/data-BKVince/d2rloader/plugins/*-src/build/

# Variables d'environnement
.env
.env.*
!.env.example

# Netlify
.netlify/
deno.lock

# Reverse engineering D2R : images du jeu, projets Ghidra et index locaux.
# Les manifestes, notes et outils reproductibles restent versionnes.
/analysis-cache/
reverse-engineering/**/analysis-cache/

# Reference externe : guide D2R communautaire (clone local, non versionne)
guide/

# Atelier de donnees : HD/local de TCP et BK sont versionnes.
# BT et le profil launcher TCP restent locaux; ses modules Runtime sont versionnes.
data-BT/hd/
data-TCP/D2RLAN/*
!data-TCP/D2RLAN/Runtime/
!data-TCP/D2RLAN/Runtime/**

# Reference VNP : versionner uniquement global/local/hd, ignorer tout le reste.
data-VNP/*
!data-VNP/VNP-MP.mpq/
data-VNP/VNP-MP.mpq/*
!data-VNP/VNP-MP.mpq/data/
data-VNP/VNP-MP.mpq/data/*
!data-VNP/VNP-MP.mpq/data/global/
!data-VNP/VNP-MP.mpq/data/global/**
!data-VNP/VNP-MP.mpq/data/local/
!data-VNP/VNP-MP.mpq/data/local/**
!data-VNP/VNP-MP.mpq/data/hd/
!data-VNP/VNP-MP.mpq/data/hd/**

# Reference vanilla D2R 3.2 extraite avec CASCView :
# versionner uniquement data/global/excel; conserver le reste local.
data-vanilla3.2/*
!data-vanilla3.2/data/
data-vanilla3.2/data/*
!data-vanilla3.2/data/data/
data-vanilla3.2/data/data/*
!data-vanilla3.2/data/data/global/
data-vanilla3.2/data/data/global/*
!data-vanilla3.2/data/data/global/excel/
!data-vanilla3.2/data/data/global/excel/**

# Backups automatiques des tables (gardes localement, non versionnes)
*.bak

# Divers
.DS_Store
desktop.ini
__pycache__/
*.pyc
*.log
!data-vanilla3.2/data/data/global/excel/**/*.log
