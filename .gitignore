# Dependances
node_modules/

# Sorties de build
dist/
.turbo/

# Variables d'environnement
.env
.env.*
!.env.example

# Netlify
.netlify/
deno.lock

# Reference externe : guide D2R communautaire (clone local, non versionne)
guide/

# Atelier de donnees : les assets HD vivent avec le jeu, hors git (stock local conserve)
data-BK/hd/
data-BT/hd/
data-TCP/hd/
data-TCP/D2RLAN/

# Reference VNP : versionner uniquement global/local/hd, ignorer tout le reste.
data-VNP/*
!data-VNP/VNP-MP.mpq/
data-VNP/VNP-MP.mpq/*
!data-VNP/VNP-MP.mpq/data/
data-VNP/VNP-MP.mpq/data/*
!data-VNP/VNP-MP.mpq/data/global/
!data-VNP/VNP-MP.mpq/data/global/**
!data-VNP/VNP-MP.mpq/data/local/
!data-VNP/VNP-MP.mpq/data/local/**
!data-VNP/VNP-MP.mpq/data/hd/
!data-VNP/VNP-MP.mpq/data/hd/**

# Backups automatiques des tables (gardes localement, non versionnes)
*.bak

# Divers
.DS_Store
*.log
