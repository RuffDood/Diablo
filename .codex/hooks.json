{
  "description": "Enforces Diablo cadastre, Git authorization, and verification gates.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/diablo-guard.mjs\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$repo = git rev-parse --show-toplevel; node (Join-Path $repo '.codex/hooks/diablo-guard.mjs')\"",
            "timeout": 30,
            "statusMessage": "Checking dedicated Git authorization"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/diablo-guard.mjs\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$repo = git rev-parse --show-toplevel; node (Join-Path $repo '.codex/hooks/diablo-guard.mjs')\"",
            "timeout": 30,
            "statusMessage": "Enforcing Diablo repository policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/diablo-guard.mjs\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$repo = git rev-parse --show-toplevel; node (Join-Path $repo '.codex/hooks/diablo-guard.mjs')\"",
            "timeout": 120,
            "statusMessage": "Checking cadastre and modified D2R tables"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/diablo-guard.mjs\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$repo = git rev-parse --show-toplevel; node (Join-Path $repo '.codex/hooks/diablo-guard.mjs')\"",
            "timeout": 600,
            "statusMessage": "Running mandatory completion checks"
          }
        ]
      }
    ]
  }
}
