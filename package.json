{
  "name": "diablo",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "verify": "node scripts/verify/verify.mjs",
    "dev": "concurrently -n api,web -c blue,green \"node scripts/dev-server.js\" \"npm run dev -w apps/admin\"",
    "dev:hero-editor": "npm run dev -w apps/hero-editor",
    "build": "turbo run build",
    "verify:data": "npm run test:gem-storage && npm run test:pandemonium-storage && npm run test:cube-guide && npm run test:itemstatcost && npm run test:bkvince-startup-refs && npm run test:bkvince-monstats-lots && npm run test:bkvince-storage-bag && npm run test:bkvince-super-tk && npm run test:bkvince-itemtypes && npm run test:bkvince-staffmods",
    "preview": "turbo run preview",
    "generate:schemas": "node scripts/build-data/gen-schemas.js",
    "generate:gem-storage": "node scripts/build-data/gem-storage.js",
    "test:gem-storage": "node scripts/build-data/gem-storage.js --check",
    "generate:pandemonium-storage": "node scripts/build-data/pandemonium-storage.js",
    "test:pandemonium-storage": "node scripts/build-data/pandemonium-storage.js --check",
    "generate:cube-guide": "node scripts/build-data/cube-guide.js",
    "test:cube-guide": "node scripts/build-data/cube-guide.js --check",
    "test:itemstatcost": "node scripts/build-data/audit-itemstatcost.js",
    "test:bkvince-startup-refs": "node scripts/migrate-bkvince/validate-startup-references.js",
    "reset:personnage": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reset-test-character.ps1",
    "test:bkvince-monstats-lots": "node scripts/migrate-bkvince/apply-monstats-lots.js",
    "generate:bkvince-storage-bag": "node scripts/migrate-bkvince/port-storage-bag.js",
    "test:bkvince-storage-bag": "node scripts/migrate-bkvince/port-storage-bag.js --check",
    "generate:bkvince-enhanced-effects": "node scripts/migrate-bkvince/import-enhanced-effects.js",
    "test:bkvince-enhanced-effects": "node scripts/migrate-bkvince/import-enhanced-effects.js --check",
    "generate:bkvince-mercenary-command": "node scripts/migrate-bkvince/port-mercenary-command.js",
    "test:bkvince-mercenary-command": "node scripts/migrate-bkvince/port-mercenary-command.js --check",
    "generate:bkvince-super-tk": "node scripts/migrate-bkvince/port-super-tk.js",
    "test:bkvince-super-tk": "node scripts/migrate-bkvince/port-super-tk.js --check",
    "generate:bkvince-itemtypes": "node scripts/migrate-bkvince/rebuild-itemtypes.js",
    "test:bkvince-itemtypes": "node scripts/migrate-bkvince/rebuild-itemtypes.js --check",
    "generate:bkvince-staffmods": "node scripts/migrate-bkvince/generate-staffmod-patch.mjs",
    "test:bkvince-staffmods": "node scripts/migrate-bkvince/generate-staffmod-patch.mjs --check",
    "native:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Build-NativePlugins.ps1",
    "re:tools": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Runtime-Tools.ps1",
    "re:d2r32:capture": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Capture-D2RRuntime.ps1",
    "re:d2r32": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/d2r32.ps1",
    "re:refs": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/references.ps1",
    "ref:d2moo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/references.ps1 -Reference d2moo",
    "ref:d2ssharp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/references.ps1 -Reference d2ssharp",
    "ref:d2rlplugins": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/references.ps1 -Reference d2rlplugins",
    "re:d2r32:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Initialize-D2R32Workbench.ps1",
    "re:d2r32:ghidra-import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Import-D2R32Ghidra.ps1",
    "re:d2r32:ghidra": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reverse-engineering/Invoke-D2R32Ghidra.ps1"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "concurrently": "^9.1.2",
    "turbo": "^2.10.5"
  }
}
