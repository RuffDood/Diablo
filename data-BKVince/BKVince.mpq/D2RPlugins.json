{
    // ── Items ─────────────────────────────────────────────────────────────────
    "items": {
        // Spawn magic/rare items pre-identified.
        "magicItemsSpawnIdentified": false,
        "rareItemsSpawnIdentified": false,

        // Remove the gold-penalty formula that reduces gold picked up at high levels.
        "disableGoldPenalty": false,

        // Raise the inventory gold cap beyond the vanilla per-level formula.
        // mode: "disabled" | "perLevel" | "flat"
        // value: cap to use when mode is "flat", or additive bonus when "perLevel".
        "inventoryGoldLimit": {
            "mode": "disabled",
            "value": 10000
        },

        // Allow runewords to be created in non-normal-quality items.
        // Each key enables that quality: magic / set / rare / unique / crafted / tempered.
        "runewordQualities": {
            "magic":    false,
            "set":      false,
            "rare":     false,
            "unique":   false,
            "crafted":  false,
            "tempered": false
        },

        // Control which items appear on the gambling screen.
        // mode: "disabled" | "noRingAmuletGuarantee" | "bitfield"
        //   noRingAmuletGuarantee – removes the forced ring/amulet in the first two slots.
        //   bitfield              – only show items whose dwBitField1 & bitfield != 0.
        "gambleFilter": {
            "mode": "disabled",
            "bitfield": 4
        },

        // Vendor overhaul: replaces the vanilla random-item generator for shops.
        "vendorOverhaul": {
            "enabled": false,

            // Item level below which vendor items spawn as Normal quality.
            "normalItemLevelMaxThreshold": 25,
            // Item level at or above which vendor items can spawn as Magic.
            "magicMinLevelThreshold": 0,
            // Item level at or above which vendor items can spawn as Superior.
            "superiorMinLevelThreshold": 5,
            // Item level below which vendor items can spawn as Low Quality.
            "lowQualityMaxLevelThreshold": 5,

            // Percentage chance (0–100) for an eligible item to be upgraded to Superior.
            "superiorUpgradeChance": 25,
            // Percentage chance (0–100) for an eligible item to be downgraded to Low Quality.
            "lowQualityDowngradeChance": 10,

            // Allow vendors to occasionally sell Rare items.
            "randomRareItems": false,
            // Denominator for the rare-item chance (1-in-N per slot). Default 1024.
            "rareItemChance": 1024,

            // Vendor difficulty upgrade thresholds.
            // These control how aggressively vendors sell exceptional/elite items.
            // A value of 0 disables the override and keeps vanilla behaviour.
            //   NightmareBaseChance / HellUberBaseChance / HellBaseChance:
            //     Added to (player_level << levelScale) to get the upgrade roll threshold.
            //   *LevelScale: the SHL shift count (power-of-2 multiplier on player level).
            "nightmareBaseChance":  4000,  // vanilla: 4000
            "hellUberBaseChance":   5000,  // vanilla: 5000
            "hellBaseChance":       1000,  // vanilla: 1000
            "nightmareLevelScale":  64,    // vanilla: 64  (SHL 6)
            "hellUberLevelScale":   128,   // vanilla: 128 (SHL 7)
            "hellLevelScale":       16     // vanilla: 16  (SHL 4)
        },

        // Use the attacking player unit (instead of the monster) when evaluating
        // ConditionCalc expressions in Treasure Class records.
        "playerConditionCalc": false,

        // Override the maximum physical resistance cap (vanilla: 50%).
        "physResistCap": {
            "enabled": false,
            "max": 50
        },

        // Override the maximum elemental resistance cap (vanilla: 95%).
        "elementalResistCap": {
            "enabled": false,
            "max": 95
        },

        // Override the maximum absorb percentage cap (vanilla: 40%).
        "absorbCap": {
            "enabled": false,
            "max": 40
        }
    },

    // ── Skills ────────────────────────────────────────────────────────────────
    "skills": {
        // Read the "ManaCostsLife" / "ManaCostsStamina" columns from skills.txt
        // and route mana costs to HP or stamina instead.
        "manaCostsLife":    false,
        "manaCostsStamina": false,

        // Restore classic Whirlwind behaviour: no cooldown between individual hits.
        "classicWhirlwind": false,

        // Allow Whirlwind to trigger Chance-to-Cast modifiers on gear.
        "whirlwindCtC": false,

        // Telekinesis picks up any item (not just gold and scrolls).
        "telekinesisPicksUpEverything": false,

        // Give charged items a % chance to not consume a charge on use.
        // statId is the character stat (0–511) that holds the skip-chance (0–100%).
        "chargedPctDrainStat": {
            "enabled": false,
            "statId": 0
        },

        // Adds additional properties to srvdofunc 169:
        // par1 set to 0 (default) will heal TO a percentage. par1 set to 1 will heal BY a percentage.
        // par2 set to 0 (default) will heal life. par2 set to 1 will heal mana.
        "selfHealParams": false
    },

    // ── Levels ────────────────────────────────────────────────────────────────
    "levels": {
        // Remove the dirt-path overlay that covers the Blood Moor in Act 1.
        "disableAct1Path": false
    },

    // ── Misc ──────────────────────────────────────────────────────────────────
    "misc": {
        // Maximum value accepted by the /players command (vanilla cap: 8).
        // Values above 8 install hooks to bypass the engine clamp.
        "playersCommandLimit": 8,

        // Cap the effective player count used when computing each monster's
        // /players bonus to monster max HP / experience. 0 disables the cap
        // (vanilla behaviour: scales with the real /players value, up to 8).
        // Set to 1 to remove that stat's /players scaling entirely. The two
        // caps are independent of each other and of the real /players value.
        "monsterHpPlayerCountCap": 8,
        "monsterExperiencePlayerCountCap": 0
    },

    // ── Quests ────────────────────────────────────────────────────────────────
    "quests": {
        // Den of Evil (Act 1) – extra skill point reward.
        // mode: "disabled" | "same" | "different"
        //   same      – all difficulties give the same reward.
        //   different – per-difficulty rewards via the perDifficulty array.
        "denOfEvil": {
            "mode": "disabled",
            "skillPoints": 1
        },

        // Izual (Act 4) – extra skill point reward.
        "izual": {
            "mode": "disabled",
            "skillPoints": 2
        },

        // The Black Book (Act 2) – extra stat point reward.
        "blackBook": {
            "mode": "disabled",
            "statPoints": 5
        },

        // The Golden Bird (Act 3) – bonus to a character stat.
        // stat: stat ID to modify. amount: value added (HP/MP are in 256ths).
        "goldenBird": {
            "mode": "disabled",
            "stat": 7,
            "amount": 5120   // 5120 / 256 = 20 HP
        },

        // Radament's Lair (Act 2) – skill book reward.
        // stat: stat ID to modify. amount: how much to add.
        "radamentSkillBook": {
            "mode": "disabled",
            "stat": 5,
            "amount": 1
        },

        // Akara / Cain rescue ring reward.
        // item: 3-character item code (e.g. "rin").
        // quality: 2=Normal 3=Superior 4=Magic 5=Set 6=Rare 7=Unique 8=Crafted 9=Tempered
        // perDifficulty: array of [normal, nightmare, hell] overrides when mode is "different".
        "akaraCainRing": {
            "mode": "disabled",
            "item": "rin",
            "quality": 6,
            "perDifficulty": [
                { "item": "rin", "quality": 6 },
                { "item": "rin", "quality": 6 },
                { "item": "rin", "quality": 6 }
            ]
        },

        // Ormus / Gidbinn ring reward.
        "ormusGidbinnRing": {
            "mode": "disabled",
            "item": "rin",
            "quality": 6,
            "perDifficulty": [
                { "item": "rin", "quality": 6 },
                { "item": "rin", "quality": 6 },
                { "item": "rin", "quality": 6 }
            ]
        },

        // Qual-Kehk rescue rune rewards (three rune slots).
        // items: array of 3 item codes for the "same" reward across all difficulties.
        // perDifficulty: 3-element array (normal / nightmare / hell), each containing
        //   a 3-element array of item codes for the three rune slots.
        "qualKehkRunes": {
            "mode": "disabled",
            "items": [ "r07", "r08", "r09" ],
            "perDifficulty": [
                [ "r07", "r08", "r09" ],   // Normal
                [ "r07", "r08", "r09" ],   // Nightmare
                [ "r07", "r08", "r09" ]    // Hell
            ]
        },

        // Allow the Imbue quest reward to be used on socketed items.
        "imbueAllowSockets": false
    }
}
