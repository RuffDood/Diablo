{
    // Ctrl + click invests up to this many points without confirmation.
    // Accepted range: 1 through 1000. Native allocation rules can stop earlier.
    "skillPointsPerCtrlClick": 5,

    // Shift + click works like stat allocation and asks for confirmation before investing all usable points.
    // Edit BulkSkillPointAllocation.strings.json to translate the prompt.

    // Emit native bulk diagnostics in the D2RLoader log.
    "diagnostics": false
}
